# Database Configuration
POSTGRES_USER=<YOUR_NAME_FOR_POSTGRES>
POSTGRES_PASSWORD=<PASSWORD>
POSTGRES_DB=<NAME_OF_DATABASE>
POSTGRES_PORT=<PORT_WHERE_THE_DATABASE_WILL_LISTEN>

# Node.js Application
NODE_ENV=<GIVE_THIS_A_NAME_WHERE_IT_IS_DEPLOYED_FOR_EXAMPLE_development>
PORT=<PORT_WHERE_THE_BACKEND_APPLICATION_RUNS>

# Database URL (constructed from above variables)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# For JWT
ACCESS_TOKEN_SECRET=<GENERATE_A_HEX_VALUE_RANDOM_OF_LENGTH_128>

REFRESH_TOKEN_SECRET=<GENERATE_A_HEX_VALUE_RANDOM_OF_LENGTH_128>

#Rename this file to ".env" in this location itself